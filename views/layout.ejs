<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= (typeof pageTitle !== 'undefined' && pageTitle) ? pageTitle : '009 Compliance | FCA Compliance Authorisation Assistance' %></title>

<meta name="description" content="<%= (typeof pageDescription !== 'undefined' && pageDescription) ? pageDescription : 'Monthly FCA compliance reporting portal for motor dealers. Submit MI, track submissions, and maintain evidence-ready records with 009 Compliance.' %>">

<link rel="canonical" href="<%= (typeof canonicalUrl !== 'undefined' && canonicalUrl) ? canonicalUrl : '' %>">

<meta name="robots" content="<%= (typeof robots !== 'undefined' && robots) ? robots : 'index,follow' %>">
<meta property="og:title" content="<%= (typeof ogTitle !== 'undefined' && ogTitle) ? ogTitle : ((typeof pageTitle !== 'undefined' && pageTitle) ? pageTitle : '009 Compliance | FCA Compliance Reporting Portal') %>">
<meta property="og:description" content="<%= (typeof ogDescription !== 'undefined' && ogDescription) ? ogDescription : ((typeof pageDescription !== 'undefined' && pageDescription) ? pageDescription : 'Monthly FCA compliance reporting portal for motor dealers. Submit MI, track submissions, and maintain evidence-ready records with 009 Compliance.') %>">
<meta property="og:type" content="<%= (typeof ogType !== 'undefined' && ogType) ? ogType : 'website' %>">
<meta property="og:url" content="<%= (typeof canonicalUrl !== 'undefined' && canonicalUrl) ? canonicalUrl : '' %>">
<meta property="og:site_name" content="009 Compliance">
<meta property="og:image" content="<%= (typeof ogImage !== 'undefined' && ogImage) ? ogImage : 'https://009compliance.com/images/logo1resized.png' %>">
<meta property="og:image:width" content="512">
<meta property="og:image:height" content="512">
<meta property="og:image:alt" content="009 Compliance logo">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= (typeof ogTitle !== 'undefined' && ogTitle) ? ogTitle : ((typeof pageTitle !== 'undefined' && pageTitle) ? pageTitle : '009 Compliance | FCA Compliance Reporting Portal') %>">
<meta name="twitter:description" content="<%= (typeof ogDescription !== 'undefined' && ogDescription) ? ogDescription : ((typeof pageDescription !== 'undefined' && pageDescription) ? pageDescription : 'Monthly FCA compliance reporting portal for motor dealers. Submit MI, track submissions, and maintain evidence-ready records with 009 Compliance.') %>">
<meta name="twitter:image" content="<%= (typeof ogImage !== 'undefined' && ogImage) ? ogImage : 'https://009compliance.com/images/logo1resized.png' %>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- Schema.org Organization -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://009compliance.com/#organization",
  "name": "009 Compliance",
  "url": "https://009compliance.com",
  "logo": "https://009compliance.com/images/logo1resized.png",
  "email": "info@009compliance.com",
  "telephone": "03300432377",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Hilton Jones Hollinwood Business Centre, Albert Street",
    "addressLocality": "Oldham",
    "postalCode": "OL8 3QL",
    "addressCountry": "GB"
  }
}
</script>

<% if (typeof pageSchema !== 'undefined' && pageSchema) { %>
  <% (Array.isArray(pageSchema) ? pageSchema : [pageSchema]).forEach((schemaItem) => { %>
<script type="application/ld+json">
<%- JSON.stringify(schemaItem, null, 2) %>
</script>
  <% }) %>
<% } %>

  <!-- Google tag (gtag.js) -->
   <script async src="https://www.googletagmanager.com/gtag/js?id=G-BMQFTHWWKP"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-BMQFTHWWKP');
</script>

  <!-- FAVICONS: light & dark mode -->
   <link rel="icon" type="image/png" href="/logo-dark.png" media="(prefers-color-scheme: light)">
   <link rel="icon" type="image/png" href="/logo-light.png" media="(prefers-color-scheme: dark)">
   <link rel="apple-touch-icon" href="/logo-dark.png">

  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" integrity="sha512-iqXNtL4GKJ8VimG/rI3iZ4prJ7pXSq6X7P0QakHEzKirMld7ObZfM/C1Jr+6r7aqtmLbXR4Yg8lJWS1d76Z0TQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <link rel="stylesheet" href="/css/styles.css" />
</head>

<body class="bg-slate-950 text-slate-50 min-h-screen flex flex-col">

<header class="border-b border-slate-800 bg-slate-950/80 backdrop-blur sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center gap-6">
    <!-- LEFT: logo -->
    <a href="/" class="flex items-center gap-3 shrink-0">
      <img src="/images/logo1resized.png" alt="009 Compliance" width="512" height="512" fetchpriority="high" class="h-16 md:h-20 w-auto object-contain" />
      <!-- Hide the long subtitle on smaller screens so it never collides -->
      <div class="hidden xl:flex flex-col leading-tight">
        <span class="font-semibold tracking-tight text-slate-50">009 Compliance</span>
        <span class="text-xs text-slate-400">FCA Compliance and Reporting Support for Motor Dealers</span>
      </div>
    </a>

    <!-- DESKTOP NAV -->
    <nav class="hidden lg:flex items-center gap-8 text-sm mx-auto">
      <a href="/" class="hover:text-emerald-400 transition">Home</a>
      <a href="/about" class="hover:text-emerald-400 transition">About</a>
      <div class="relative group">
        <a
          href="/services"
          class="inline-flex items-center gap-1 hover:text-emerald-400 transition"
          aria-haspopup="true"
        >
          Services
          <span class="text-xs" aria-hidden="true">▾</span>
        </a>
        <div class="pointer-events-none absolute left-1/2 top-full z-50 w-64 -translate-x-1/2 translate-y-2 pt-3 opacity-0 transition-all duration-200 ease-out group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100">
          <div class="rounded-xl border border-slate-200 bg-white p-2 shadow-2xl shadow-slate-950/20">
            <a href="/fca-authorisation-motor-dealers" class="block rounded-lg px-3 py-2 text-slate-800 hover:bg-emerald-50 hover:text-emerald-700 transition">
              FCA Authorisation for Motor Dealers
            </a>
            <a href="/motor-dealer-compliance" class="block rounded-lg px-3 py-2 text-slate-800 hover:bg-emerald-50 hover:text-emerald-700 transition">
              Motor Dealer Compliance Support
            </a>
            <a href="/ccr009-return-assistance-motor-dealers" class="block rounded-lg px-3 py-2 text-slate-800 hover:bg-emerald-50 hover:text-emerald-700 transition">
              CCR009 Return Assistance
            </a>
          </div>
        </div>
      </div>
      <a href="/contact" class="hover:text-emerald-400 transition">Contact</a>
      <a href="/pricing" class="hover:text-emerald-400 transition">Pricing</a>
    </nav>

    <!-- RIGHT: auth buttons (desktop) -->
    <div class="hidden lg:flex items-center gap-4 shrink-0">
      <% if (currentUser) { %>
        <a href="/dashboard" class="hover:text-emerald-400 transition">Dashboard</a>
        <span class="text-slate-500 hidden xl:inline">
          Signed in as <span class="text-slate-100"><%= currentUser.name %></span>
        </span>
        <a href="/logout"
          class="px-3 py-1 rounded-lg border border-slate-700 hover:border-emerald-500 hover:text-emerald-400 transition">
          Log out
        </a>
      <% } else { %>
        <a href="/login" class="hover:text-emerald-400 transition">Log in</a>
        <a href="/register"
          class="px-3 py-1 rounded-lg bg-emerald-500 text-slate-900 font-semibold hover:bg-emerald-400 transition">
          Get started
        </a>
      <% } %>
    </div>

    <!-- MOBILE BUTTON -->
    <button
      id="mobileMenuBtn"
      class="lg:hidden ml-auto inline-flex items-center justify-center w-10 h-10 rounded-lg border border-slate-800 text-slate-200"
      aria-label="Open menu"
      type="button"
    >
      ☰
    </button>
  </div>

 <!-- MOBILE MENU PANEL -->
<div id="mobileMenu" class="lg:hidden hidden border-t border-slate-200 bg-white text-slate-900">
  <div class="max-w-7xl mx-auto px-6 py-4 space-y-3 text-sm">
    <a href="/" class="block hover:text-orange-500 transition">Home</a>
    <a href="/about" class="block hover:text-orange-500 transition">About</a>
    <a href="/services" class="block hover:text-orange-500 transition">Services</a>
    <div class="pl-4 space-y-2 border-l border-slate-200">
      <a href="/fca-authorisation-motor-dealers" class="block hover:text-orange-500 transition">FCA Authorisation for Motor Dealers</a>
      <a href="/motor-dealer-compliance" class="block hover:text-orange-500 transition">Motor Dealer Compliance Support</a>
      <a href="/ccr009-return-assistance-motor-dealers" class="block hover:text-orange-500 transition">CCR009 Return Assistance</a>
    </div>
    <a href="/contact" class="block hover:text-orange-500 transition">Contact</a>
    <a href="/pricing" class="block hover:text-orange-500 transition">Pricing</a>

    <div class="pt-3 border-t border-slate-200 flex items-center gap-3">
      <% if (currentUser) { %>
        <a href="/dashboard" class="hover:text-orange-500 transition">Dashboard</a>
        <a href="/logout"
          class="ml-auto px-3 py-1 rounded-lg border border-slate-300 hover:border-orange-500 hover:text-orange-500 transition">
          Log out
        </a>
      <% } else { %>
        <a href="/login" class="hover:text-orange-500 transition">Log in</a>
        <a href="/register"
          class="ml-auto px-3 py-1 rounded-lg bg-orange-500 text-white font-semibold hover:bg-orange-400 transition">
          Get started
        </a>
      <% } %>
    </div>
  </div>
</div>
</header>

<script>
  (function () {
    const btn = document.getElementById('mobileMenuBtn');
    const menu = document.getElementById('mobileMenu');
    if (!btn || !menu) return;

    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  })();
</script>

  <main class="flex-1">
    <div class="max-w-screen-2xl mx-auto px-6 py-6">
      <% if (success && success.length) { %>
        <div class="mb-4 rounded-xl border border-emerald-500/50 bg-emerald-500/5 px-4 py-3 text-sm text-emerald-200">
          <%= success[0] %>
        </div>
      <% } %>

      <% if (error && error.length) { %>
        <div class="mb-4 rounded-xl border border-rose-500/50 bg-rose-500/5 px-4 py-3 text-sm text-rose-200">
          <%= error[0] %>
        </div>
      <% } %>

      <%- body %>
    </div>
  </main>

  <footer class="border-t border-slate-800 py-6 mt-8">
    <div class="max-w-7xl mx-auto px-6 flex flex-col gap-3 text-xs text-slate-500">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
        <p>© <%= new Date().getFullYear() %> Nothing Burger Media, 009 Compliance. All rights reserved.</p>
        <p>009 Compliance Ltd is a company registered in England and Wales (company number 16910484). ICO Number - ZC072139</p>
      </div>
      <nav class="flex flex-col sm:flex-row gap-2 sm:gap-5" aria-label="Footer priority service links">
        <a href="/fca-authorisation-motor-dealers" class="hover:text-orange-500 transition">FCA Authorisation for Motor Dealers</a>
        <a href="/motor-dealer-compliance" class="hover:text-orange-500 transition">Motor Dealer Compliance Support</a>
        <a href="/ccr009-return-assistance-motor-dealers" class="hover:text-orange-500 transition">CCR009 Return Assistance</a>
      </nav>
    </div>
  </footer>

    <div id="success-toast"
     class="fixed top-6 right-6 z-50 hidden max-w-sm rounded-xl border border-emerald-500/40 bg-emerald-500/10 px-5 py-4 text-sm text-emerald-200 shadow-lg backdrop-blur">
  <div class="flex items-start gap-3">
    <div class="mt-0.5 text-emerald-400">✔</div>
    <div>
      <p class="font-semibold text-emerald-300">Monthly Submission Complete</p>
      <p id="success-toast-message" class="text-emerald-200/90">
        <!-- JS will fill this -->
      </p>
    </div>
  </div>
</div>

<script>
  <% if (locals.showSubmissionToast && locals.showSubmissionToast[0] === "true") { %>
    window.__TOAST_SUCCESS__ = "You have successfully completed a Monthly Submission Form!";
  <% } %>
</script>
  <script defer src="/js/main.js"></script>
</body>
</html>
